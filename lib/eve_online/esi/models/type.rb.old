# frozen_string_literal: true

module EveOnline
  module ESI
    module Models
      class Type < Base
        def dogma_attributes
          @dogma_attributes ||= DogmaAttributes.new(options["dogma_attributes"]).dogma_attributes
        end

        def dogma_effects
          @dogma_effects ||= DogmaEffects.new(options["dogma_effects"]).dogma_effects
        end
      end
    end
  end
end
